# Fastlane Environment Variables Template
# Copy this file to .env and fill in your credentials.
# DO NOT commit the .env file to version control.

# --- Apple / iOS ---
# Your Apple ID email
FASTLANE_USER="your-apple-id@email.com"

# App-Specific Password (Generate at https://appleid.apple.com)
# This allows non-interactive uploads to TestFlight.
FASTLANE_APPLE_APPLICATION_SPECIFIC_PASSWORD="xxxx-xxxx-xxxx-xxxx"

# --- Android / Google Play ---
# Path to your Google Play Service Account JSON key file.
# The path is relative to the project root.
# ANDROID_JSON_KEY_FILE=".secrets/AndroidKeys/api-xxxx.json"
